APP_NAME="Детская лига"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Database (PostgreSQL 15) ──────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=detskaya_liga
DB_USERNAME=postgres
DB_PASSWORD=secret

# ── Logging ───────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Cache / Queue / Session ───────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Redis ─────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (SMTP) ──────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@detskayaliga.ru"
MAIL_FROM_NAME="${APP_NAME}"

# ── S3 / Object Storage ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=detskaya-liga
AWS_ENDPOINT=https://storage.yandexcloud.net
AWS_USE_PATH_STYLE_ENDPOINT=true

FILESYSTEM_DISK=s3

# ── Firebase Cloud Messaging (FCM) ───────────
FCM_SERVER_KEY=
FCM_SENDER_ID=
FCM_PROJECT_ID=

# ── Telegram Bot Notifications ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── OAuth Providers ──────────────────────────
# VK
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URL="${APP_URL}/auth/vk/callback"

# Yandex
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URL="${APP_URL}/auth/yandex/callback"

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# ── Sanctum ──────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ── Pusher / Broadcasting ────────────────────
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
