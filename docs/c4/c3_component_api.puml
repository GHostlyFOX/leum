@startuml c3_component_api
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component Diagram — Backend API (Level 3)

' ─── Callers ──────────────────────────────────────────────────────────────────
Container(web_app,    "Веб-приложение",     "Vue.js / Blade",  "")
Container(mobile_app, "Мобильное приложение", "React Native",  "")

' ─── API boundary ─────────────────────────────────────────────────────────────
Container_Boundary(api, "Backend API — Laravel") {

    ' Auth
    Component(auth_comp, "Auth Module",
        "Laravel Sanctum / Passport",
        "Регистрация, вход по email/телефону,\nOAuth2 (Google, Apple),\nсброс пароля, refresh-токены,\nразграничение прав (RBAC)")

    ' Club & Team
    Component(club_comp, "Club & Team Module",
        "Laravel Controller + Service",
        "CRUD клубов: название, логотип,\nвид, адрес, контакты.\nCRUD команд: вид спорта, год,\nпол, фото. Управление составом")

    ' People
    Component(people_comp, "People Module",
        "Laravel Controller + Service",
        "Управление игроками: основные\nданные, фото, родители.\nУправление тренерами: карьера,\nлицензия, достижения.\nПриглашения по email")

    ' Training
    Component(training_comp, "Training Module",
        "Laravel Controller + Service",
        "Создание разовых/регулярных\nтренировок, расписание по дням\nнедели, места проведения.\nПосещаемость: подтверждения\nродителей, ручные отметки тренера,\nпричины отсутствия, травмы")

    ' Tournament & Match
    Component(match_comp, "Tournament & Match Module",
        "Laravel Controller + Service",
        "Три типа турниров: товарищеский\nматч, однодневный, регулярный.\nТурнирная сетка, составы.\nЗапуск таймера матча, фиксация\nголов/ассистов/замен в реальном\nвремени. Результаты")

    ' Statistics
    Component(stats_comp, "Statistics Module",
        "Laravel Service + Query Builder",
        "Посещаемость тренировок и матчей\nпо игроку/команде/периоду.\nСтатистика голов, ассистов,\nигрового времени. Агрегация\nданных для дашборда")

    ' Notifications
    Component(notif_comp, "Notification Module",
        "Laravel Notifications + Jobs",
        "Push (FCM/APNs), Telegram.\nСобытия: новый матч, изменение\nрасписания, отмена тренировки,\nрезультат матча в реальном времени.\nНастройки отключения уведомлений")

    ' Calendar
    Component(cal_comp, "Calendar Module",
        "iCal / CalDAV Generator",
        "Экспорт расписания тренировок\nи матчей в Google Calendar\nи Apple Calendar")

    ' Import/Export
    Component(import_comp, "Import / Export Module",
        "Laravel + PhpSpreadsheet",
        "Импорт игроков из Excel по шаблону.\nЭкспорт отчётов о посещаемости\nи статистике в XLSX / CSV")

    ' File Storage
    Component(file_comp, "File Storage Module",
        "Laravel Filesystem / S3",
        "Загрузка и хранение фотографий\nигроков, тренеров\nи логотипов команд")

    ' Справочники
    Component(dict_comp, "Directory Module",
        "Laravel Controller",
        "Справочники: виды спорта,\nпозиции игроков, типы тренировок,\nместа проведения, соперники")
}

' ─── Data & External ──────────────────────────────────────────────────────────
ContainerDb(db,           "PostgreSQL",             "", "")
Container(queue,          "Queue / Redis",           "", "")
System_Ext(push_service,  "FCM / APNs",             "")
System_Ext(messengers,    "Telegram",               "")
System_Ext(oauth_ext,     "Google / Apple OAuth2",  "")
System_Ext(calendar_ext,  "Google / Apple Calendar","")

' ─── Relationships — callers → components ─────────────────────────────────────
Rel(web_app,    auth_comp,     "POST /auth/*",               "HTTPS / JSON")
Rel(web_app,    club_comp,     "CRUD /clubs, /teams",        "HTTPS / JSON")
Rel(web_app,    people_comp,   "CRUD /players, /coaches",    "HTTPS / JSON")
Rel(web_app,    training_comp, "CRUD /trainings",            "HTTPS / JSON")
Rel(web_app,    match_comp,    "CRUD /matches, /tournaments","HTTPS / JSON")
Rel(web_app,    import_comp,   "POST /import, GET /export",  "HTTPS / JSON")

Rel(mobile_app, auth_comp,     "POST /auth/*",               "HTTPS / JSON")
Rel(mobile_app, training_comp, "GET/PATCH /trainings",       "HTTPS / JSON")
Rel(mobile_app, match_comp,    "GET /matches, live events",  "HTTPS / JSON + WS")
Rel(mobile_app, stats_comp,    "GET /statistics",            "HTTPS / JSON")
Rel(mobile_app, notif_comp,    "PATCH /notifications/prefs", "HTTPS / JSON")

' ─── Relationships — components → infrastructure ──────────────────────────────
Rel(auth_comp,     db,           "users, roles, tokens",      "SQL")
Rel(auth_comp,     oauth_ext,    "OAuth2 code exchange",      "HTTPS")
Rel(club_comp,     db,           "clubs, teams, memberships", "SQL")
Rel(people_comp,   db,           "players, coaches, parents",  "SQL")
Rel(people_comp,   file_comp,    "Загрузка фотографий",        "Internal")
Rel(training_comp, db,           "trainings, attendance",     "SQL")
Rel(training_comp, notif_comp,   "Событие: изменение трен.",  "Internal Event")
Rel(match_comp,    db,           "matches, goals, lineups",   "SQL")
Rel(match_comp,    notif_comp,   "Событие: гол, результат",   "Internal Event")
Rel(stats_comp,    db,           "Агрегирующие запросы",      "SQL")
Rel(notif_comp,    queue,        "Dispatch notification jobs","Redis")
Rel(queue,         push_service, "Send push",                 "HTTPS / API")
Rel(queue,         messengers,   "Send messages",             "HTTPS / Bot API")
Rel(cal_comp,      calendar_ext, "Export iCal",               "HTTPS / CalDAV")
Rel(import_comp,   db,           "Batch insert players",      "SQL")
Rel(file_comp,     db,           "Хранение мета файлов",      "SQL")
Rel(dict_comp,     db,           "sport_types, positions,\ntraining_types, venues", "SQL")

@enduml
