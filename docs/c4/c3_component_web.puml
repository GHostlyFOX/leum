@startuml c3_component_web
!include lib/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component Diagram — Web Application (Level 3)

' ─── Backend API ──────────────────────────────────────────────────────────────
Container(api, "Backend API", "Laravel REST", "")

' ─── Web App boundary ─────────────────────────────────────────────────────────
Container_Boundary(web, "Веб-приложение — Vue.js / Laravel + Blade") {

    ' Router & State
    Component(router, "Router & Auth Guard", "Vue Router / Laravel Middleware", "Роутинг, защита маршрутов по роли\n(role-based access control),\nредиректы неавторизованных")

    Component(store, "Global State", "Pinia / Vuex", "Хранилище: user, club, team,\nnotifications, settings")

    ' Auth
    Component(auth_pages, "Auth Pages", "Vue Components / Blade", "Логин, регистрация, OAuth2\n(Google, Apple), восстановление\nпароля, активация по приглашению")

    ' Dashboard
    Component(dashboard, "Dashboard", "Vue Components", "Главная страница с виджетами:\nUpcoming Games, Upcoming Practices,\nAnnouncements, онбординг-чеклист")

    ' Onboarding
    Component(onboarding, "Onboarding Wizard", "Vue Stepper Component", "Пошаговое создание клуба и команды\n(только для администраторов)\nШаги: Клуб → Команда → Сезон")

    ' Club & Team
    Component(club_mgmt, "Club & Team Management", "Vue Components", "CRUD клубов и команд,\nуправление составом,\ninvite-ссылки, настройки клуба")

    ' People
    Component(people_mgmt, "People Management", "Vue Components", "Карточки игроков/тренеров/родителей,\nExcel-импорт игроков,\nприглашения по email")

    ' Training
    Component(training_pages, "Training Pages", "Vue Components", "Расписание тренировок (разовые/регулярные),\nпосещаемость, отмена/изменение,\nRSVP (для тренеров)")

    ' Calendar
    Component(calendar, "Calendar", "FullCalendar.js + Vue", "Расписание в виде календаря и списка\n(тренировки + матчи + события)")

    ' Match & Tournament
    Component(match_pages, "Match & Tournament", "Vue Components", "Матчи, турниры, турнирная сетка,\nсоставы, live-таймер (только просмотр),\nрезультаты")

    ' RSVP / Attendance
    Component(rsvp, "RSVP / Attendance", "Vue Components", "Подтверждение присутствия\n(для родителей через веб),\nпричины отсутствия")

    ' Statistics
    Component(stats_page, "Statistics Page", "Vue Components + Chart.js", "Статистика посещаемости,\nголы/ассисты по игрокам,\nэкспорт в Excel")

    ' Notifications
    Component(notif_page, "Notifications", "Vue Components", "Список уведомлений,\nнастройки push/Telegram,\nистория событий")

    ' API Client
    Component(api_client, "API Client", "Axios + Interceptors", "REST API клиент с retry logic,\nобработкой ошибок 401/403,\nавтоматическим refresh token")
}

' ─── External Services (used by Web) ──────────────────────────────────────────
System_Ext(oauth, "Google / Apple OAuth2", "")
System_Ext(push_web, "Web Push (FCM)", "")

' ─── Relationships ────────────────────────────────────────────────────────────
' Internal
Rel(router,      store,        "Проверяет auth",       "")
Rel(router,      auth_pages,   "Неавторизованный",     "")
Rel(router,      dashboard,    "Авторизованный",       "")
Rel(store,       api_client,   "Данные / Actions",     "")

' Auth flow
Rel(auth_pages,  api_client,   "POST /auth/*",         "HTTPS / JSON")
Rel(auth_pages,  oauth,        "OAuth2 popup",         "HTTPS")

' Dashboard
Rel(dashboard,   api_client,   "GET /dashboard",       "HTTPS / JSON")
Rel(dashboard,   onboarding,   "Если нет клуба",       "")

' Management
Rel(club_mgmt,   api_client,   "CRUD /clubs, /teams",  "HTTPS / JSON")
Rel(people_mgmt, api_client,   "CRUD /players, /coaches, /parents", "HTTPS / JSON")
Rel(onboarding,  api_client,   "POST /clubs, /teams",  "HTTPS / JSON")

' Training & Calendar
Rel(training_pages, api_client, "CRUD /trainings",     "HTTPS / JSON")
Rel(calendar,       api_client, "GET /trainings, /matches", "HTTPS / JSON")
Rel(rsvp,           api_client, "PATCH /attendance",   "HTTPS / JSON")

' Match
Rel(match_pages, api_client,   "CRUD /matches, /tournaments", "HTTPS / JSON")

' Stats & Notifications
Rel(stats_page,  api_client,   "GET /stats/*, GET /export", "HTTPS / JSON")
Rel(notif_page,  api_client,   "GET /notifications, PATCH /settings", "HTTPS / JSON")
Rel(notif_page,  push_web,     "Подписка на Web Push", "")

' Main API connection
Rel(api_client,  api,          "Все API запросы",      "HTTPS / JSON + Bearer")

@enduml
