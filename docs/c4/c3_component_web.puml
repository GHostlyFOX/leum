@startuml c3_component_web
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component Diagram — Web Application (Level 3)

' ─── Actors ───────────────────────────────────────────────────────────────────
Person(admin,  "Администратор", "")
Person(coach,  "Тренер",        "")
Person(parent, "Родитель",      "")
Person(player, "Игрок",         "")

' ─── Web App boundary ───────────────────────────────────────────────────────
Container_Boundary(web, "Веб-приложение (Laravel + Vue.js)") {

    ' Auth
    Component(auth_page, "Auth Pages",
        "Vue.js / Blade",
        "Логин по email/телефону + пароль.\nОAuth (Google / Apple).\nРегистрация, сброс пароля.\nАктивация по ссылке-приглашению")

    ' Dashboard
    Component(dashboard, "Dashboard",
        "Vue.js Component",
        "Главная страница по роли:\nАдмин/Тренер: сводка + быстрые действия.\nРодитель: ближайшие события + RSVP.\nИгрок: расписание + статистика")

    ' Onboarding
    Component(onboarding, "Onboarding Wizard",
        "Vue.js Component",
        "Пошаговое создание клуба,\nкоманды, добавление тренера\nи игроков (только для админа)")

    ' Club & Team Management
    Component(club_mgmt, "Club & Team Management",
        "Vue.js Component",
        "CRUD клубов и команд.\nУправление составом.\nЗагрузка логотипов.\n(Админ / Тренер)")

    ' Player & Coach Cards
    Component(people_mgmt, "People Management",
        "Vue.js Component",
        "Карточки игроков и тренеров.\nПрофили, документы, родители.\nExcel-импорт игроков.\n(Админ / Тренер)")

    ' Training Module
    Component(training_page, "Training Pages",
        "Vue.js Component",
        "Создание разовых/регулярных\nтренировок. Отметка посещаемости.\n(Админ / Тренер)\nПросмотр расписания и RSVP.\n(Все роли)")

    ' Calendar
    Component(calendar_page, "Calendar",
        "Vue.js Component",
        "Расписание в виде календаря\nили списка. Переключение вида.\nПрошедшие — серые,\nпредстоящие — выделены.\n(Все роли)")

    ' Match & Tournament
    Component(match_page, "Match & Tournament Pages",
        "Vue.js Component",
        "Создание матчей/турниров.\nТурнирная сетка.\nLive-таймер, события, голы.\n(Админ / Тренер)\nПросмотр матчей и результатов.\n(Все роли)")

    ' RSVP
    Component(rsvp_page, "RSVP / Attendance",
        "Vue.js Component",
        "Подтверждение присутствия\nна тренировках и матчах.\nВыбор причины отсутствия.\nАвто-пометка при травме.\n(Родитель через веб)")

    ' Statistics
    Component(stats_page, "Statistics Page",
        "Vue.js Component",
        "Посещаемость, голы, ассисты,\nигровое время по игроку/команде.\nФильтр по периоду.\nЭкспорт в Excel.\n(Все роли)")

    ' Notifications
    Component(notif_page, "Notifications & Settings",
        "Vue.js Component",
        "Список уведомлений.\nНастройки: push/Telegram\nвключить/отключить по типу.\n(Все роли)")

    ' API Client
    Component(api_client_web, "API Client (Axios)",
        "JavaScript / Vue Plugin",
        "REST-клиент: Bearer token,\ninterceptors, error handling.\nWebSocket для live-событий")
}

' ─── External ─────────────────────────────────────────────────────────────────
Container(backend_api, "Backend API",      "Laravel REST + WS", "")

' ─── Relationships — User → Pages ────────────────────────────────────────────
Rel(admin,  auth_page,     "Входит в систему",           "")
Rel(admin,  onboarding,    "Создаёт клуб и команду",     "")
Rel(admin,  club_mgmt,     "Управляет клубом",           "")
Rel(admin,  people_mgmt,   "Управляет составом",         "")
Rel(admin,  training_page, "Создаёт тренировки",         "")
Rel(admin,  match_page,    "Создаёт матчи / турниры",    "")
Rel(admin,  stats_page,    "Смотрит статистику",         "")

Rel(coach,  auth_page,     "Входит в систему",           "")
Rel(coach,  training_page, "Создаёт тренировки",         "")
Rel(coach,  match_page,    "Ведёт матчи",                "")
Rel(coach,  stats_page,    "Смотрит статистику",         "")

Rel(parent, auth_page,     "Входит в систему",           "")
Rel(parent, dashboard,     "Видит события ребёнка",      "")
Rel(parent, rsvp_page,     "Подтверждает присутствие",   "")
Rel(parent, calendar_page, "Просматривает расписание",   "")
Rel(parent, stats_page,    "Смотрит статистику ребёнка", "")
Rel(parent, notif_page,    "Управляет уведомлениями",    "")

Rel(player, auth_page,     "Входит в систему",           "")
Rel(player, dashboard,     "Видит расписание",           "")
Rel(player, calendar_page, "Просматривает расписание",   "")
Rel(player, match_page,    "Смотрит матчи и live",       "")
Rel(player, stats_page,    "Смотрит свою статистику",    "")

' ─── Relationships — Internal ────────────────────────────────────────────────
Rel(dashboard,     calendar_page,  "Открывает расписание",  "")
Rel(dashboard,     match_page,     "Открывает матч",        "")
Rel(calendar_page, training_page,  "Открывает тренировку",  "")
Rel(calendar_page, match_page,     "Открывает матч",        "")
Rel(training_page, rsvp_page,      "RSVP",                  "")

' ─── Relationships — to API ──────────────────────────────────────────────────
Rel(api_client_web, backend_api, "REST / WebSocket",        "HTTPS / WSS")
Rel(auth_page,      api_client_web, "POST /auth/*",         "Internal")
Rel(onboarding,     api_client_web, "POST /clubs, /teams",  "Internal")
Rel(club_mgmt,      api_client_web, "CRUD /clubs, /teams",  "Internal")
Rel(people_mgmt,    api_client_web, "CRUD /players, /coaches","Internal")
Rel(training_page,  api_client_web, "CRUD /trainings",      "Internal")
Rel(match_page,     api_client_web, "CRUD /matches, WS events","Internal")
Rel(rsvp_page,      api_client_web, "PATCH /attendance",    "Internal")
Rel(calendar_page,  api_client_web, "GET /trainings, /matches","Internal")
Rel(stats_page,     api_client_web, "GET /statistics",      "Internal")
Rel(notif_page,     api_client_web, "PATCH /notifications", "Internal")

@enduml
