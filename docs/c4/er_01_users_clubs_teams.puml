' --- география ---
country ||--o{ city        : "страна"
country ||--o{ club        : ""
country ||--o{ team        : ""
city    ||--o{ club        : ""
city    ||--o{ team        : ""

' --- файлы ---
file ||--o| usr    : "фото профиля"
file ||--o| club   : "логотип клуба"
file ||--o| team   : "логотип команды"

' --- пользователи ---
usr ||--o| player       : "профиль игрока"
usr ||--o| coach        : "профиль тренера"
usr ||--o{ member       : "участие в командах"
usr ||--o{ parent_link  : "как родитель"
usr ||--o{ parent_link  : "как ребёнок"

' --- клубы / команды ---
club ||--o{ team        : "команды клуба"
club ||--o{ member      : ""
