sport   ||--o{ position    : "вид спорта"
sport   ||--o{ player      : ""
sport   ||--o{ coach       : ""
sport   ||--o{ club        : ""
sport   ||--o{ team        : ""

position ||--o{ player     : "позиция игрока"
position ||--o{ coach      : "специализация"

