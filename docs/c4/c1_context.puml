@startuml c1_context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context — Сбор (SquadUp.ru) (Level 1)

' ─── Actors ───────────────────────────────────────────────────────────────────
Person(admin,      "Администратор",  "Управляет клубом, командами,\nтренировками, турнирами и матчами")
Person(coach,      "Тренер",         "Ведёт тренировки, фиксирует\nпосещаемость и результаты матчей")
Person(parent,     "Родитель",       "Подтверждает посещаемость,\nпросматривает статистику ребёнка")
Person(player,     "Игрок",          "Просматривает расписание,\nсостав команды и статистику")

' ─── Core System ──────────────────────────────────────────────────────────────
System(sbor_platform, "Сбор (SquadUp.ru)",
    "Веб-сайт + мобильное приложение\nдля управления детскими\nспортивными командами")

' ─── External Systems ─────────────────────────────────────────────────────────
System_Ext(push_service,   "Push-уведомления\n(FCM / APNs)",   "Доставка push-уведомлений\nна мобильные устройства")
System_Ext(google_cal,     "Google Calendar",                  "Синхронизация расписания\nтренировок и матчей")
System_Ext(apple_cal,      "Apple Calendar",                   "Синхронизация расписания\nдля пользователей iOS")
System_Ext(telegram,       "Telegram Bot API",                 "Отправка уведомлений\nчерез Telegram")
System_Ext(google_auth,    "Google Identity",                  "OAuth2 авторизация\nчерез Google")
System_Ext(apple_auth,     "Sign in with Apple",               "OAuth2 авторизация\nчерез Apple ID")
System_Ext(excel_import,   "Excel / CSV",                      "Импорт/экспорт списков\nигроков и данных")

' ─── Relationships ────────────────────────────────────────────────────────────
Rel(admin,  sbor_platform, "Управляет клубом,\nкомандами, турнирами",     "HTTPS / Web")
Rel(coach,  sbor_platform, "Ведёт тренировки,\nфиксирует матчи",          "HTTPS / Web + Mobile")
Rel(parent, sbor_platform, "RSVP, календарь, статистика\nребёнка, уведомления",        "HTTPS / Web + Mobile")
Rel(player, sbor_platform, "Расписание, состав, статистика,\nlive-матчи, уведомления",    "HTTPS / Web + Mobile")

Rel(sbor_platform, push_service, "Отправляет push-уведомления",  "HTTPS / API")
Rel(sbor_platform, google_cal,   "Экспортирует расписание",       "CalDAV / iCal")
Rel(sbor_platform, apple_cal,    "Экспортирует расписание",       "CalDAV / iCal")
Rel(sbor_platform, telegram,     "Отправляет уведомления",        "Bot API")
Rel(sbor_platform, google_auth,  "OAuth2 авторизация",            "OAuth2 / OIDC")
Rel(sbor_platform, apple_auth,   "OAuth2 авторизация",            "Sign in with Apple")
Rel(admin,         excel_import, "Импортирует списки игроков",    "XLSX / CSV")
Rel(sbor_platform, excel_import, "Экспортирует отчёты",           "XLSX / CSV")

@enduml
