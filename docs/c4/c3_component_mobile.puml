@startuml c3_component_mobile
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component Diagram — Mobile Application (Level 3)

' ─── Backend API ──────────────────────────────────────────────────────────────
Container(api, "Backend API", "Laravel REST", "")

' ─── Mobile App boundary ──────────────────────────────────────────────────────
Container_Boundary(mobile, "Мобильное приложение — React Native / Flutter") {

    ' Navigation & State
    Component(nav, "Navigation & Auth Guard",
        "React Navigation / Flutter Navigator",
        "Роутинг, защита маршрутов по роли,\ndeep-link навигация, global state")

    Component(state_mgmt, "Global State",
        "Redux / Provider + Hive",
        "Хранилище: user, club, team,\nnotifications, offline queue")

    ' Auth
    Component(auth_screen, "Auth Screen",
        "React Native / Flutter",
        "Вход, OAuth2, Secure Storage\nдля токена, биометрия (опционально)")

    ' Home
    Component(home, "Home / Dashboard",
        "React Native / Flutter",
        "Сводка по ближайшим событиям,\nкарточка ребёнка (для родителей),\nбыстрые действия")

    ' Team
    Component(team_screen, "Team Screen",
        "React Native / Flutter",
        "Состав команды,\nкарточки игроков и тренеров,\nконтакты (позвонить/написать)")

    ' Calendar
    Component(calendar_screen, "Calendar Screen",
        "React Native / Flutter",
        "Расписание в режиме календаря\nи списка (тренировки + матчи)")

    ' Attendance / RSVP
    Component(attendance_screen, "Attendance / RSVP",
        "React Native / Flutter",
        "Подтверждение/отмена присутствия,\nпричины отсутствия (болезнь, травма),\nавто-продление при травме")

    ' Training Detail
    Component(training_detail, "Training Detail",
        "React Native / Flutter",
        "Детали тренировки,\nсписок участников со статусами,\nместо на карте (ссылка)")

    ' Match Live
    Component(match_live, "Match Live",
        "React Native / Flutter",
        "Карточка матча,\nтаймер в реальном времени,\nтекущий счёт, лента событий")

    ' Statistics
    Component(stats_screen, "Statistics Screen",
        "React Native / Flutter",
        "Посещаемость, голы, ассисты,\nминуты на поле,\nграфики по периодам")

    ' Notifications
    Component(notif_screen, "Notifications",
        "React Native / Flutter",
        "Уведомления,\nнастройки отключения по типам,\nTelegram-бот подключение")

    ' Offline Layer
    Component(offline_layer, "Offline Sync Layer",
        "SQLite / Hive",
        "Локальное кэширование,\nочередь отложенных запросов,\nсинхронизация при восстановлении сети")

    ' API Client
    Component(api_client, "API Client",
        "Axios / Dio",
        "REST клиент с interceptors,\nretry logic, offline queue,\nWebSocket для live-матча")

    ' Push Handler
    Component(push_handler, "Push Handler",
        "FCM SDK / APNs",
        "Обработка push-уведомлений,\nотображение local notifications,\ndeep-link навигация")
}

' ─── External Services ────────────────────────────────────────────────────────
System_Ext(fcm, "Firebase Cloud Messaging", "")
System_Ext(apns, "Apple Push Notification", "")
System_Ext(oauth, "Google / Apple OAuth2", "")

' ─── Relationships ────────────────────────────────────────────────────────────
' Internal
Rel(nav,           state_mgmt,   "Проверяет auth",       "")
Rel(nav,           auth_screen,  "Неавторизованный",     "")
Rel(nav,           home,         "Авторизованный",       "")
Rel(state_mgmt,    api_client,   "Данные / Actions",     "")
Rel(state_mgmt,    offline_layer,"Sync / Cache",         "")

' Auth
Rel(auth_screen,   api_client,   "POST /auth/*",         "HTTPS / JSON")
Rel(auth_screen,   oauth,        "OAuth2 native flow",   "HTTPS")

' Screens
Rel(home,          api_client,   "GET /dashboard",       "HTTPS / JSON")
Rel(team_screen,   api_client,   "GET /teams/{id}/members", "HTTPS / JSON")
Rel(calendar_screen, api_client, "GET /trainings, /matches", "HTTPS / JSON")

' RSVP / Attendance
Rel(attendance_screen, api_client, "PATCH /attendance, /match_players", "HTTPS / JSON")
Rel(attendance_screen, offline_layer, "Queue if offline", "")

' Training & Match
Rel(training_detail, api_client, "GET /trainings/{id}", "HTTPS / JSON")
Rel(match_live,    api_client,   "GET /matches/{id}/live", "HTTPS + WS")
Rel(match_live,    api_client,   "POST /matches/{id}/events", "HTTPS / JSON")

' Stats & Notifications
Rel(stats_screen,  api_client,   "GET /players/{id}/stats", "HTTPS / JSON")
Rel(notif_screen,  api_client,   "GET /notifications, PATCH /settings", "HTTPS / JSON")

' Push
Rel(push_handler,  fcm,          "FCM Token registration", "")
Rel(push_handler,  apns,         "APNs Token registration", "")
Rel(push_handler,  nav,          "Deep link",            "")

' API
Rel(api_client,    api,          "Все API запросы",      "HTTPS / JSON + Bearer")
Rel(offline_layer, api_client,   "Retry queued requests", "")

@enduml
